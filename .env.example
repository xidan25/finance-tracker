# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored and never committed.
# ─────────────────────────────────────────────────────────────

# Anthropic API key — used to classify transactions.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# Gmail credentials for reading card-alert emails over IMAP.
# GMAIL_APP_PASSWORD is a 16-char Google "App Password" (NOT your login
# password): https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=

# One Gmail label per card. GMAIL_LABELS is comma-separated for polling
# multiple cards daily (each label name is used as the card nickname).
# If GMAIL_LABELS is unset, the code falls back to the single GMAIL_LABEL.
GMAIL_LABEL=scotiabank visa
GMAIL_LABELS=scotiabank visa,dbs visa

# ── Notion integration ───────────────────────────────────────
# Create an internal integration at https://www.notion.so/my-integrations
# to get the token, then share your target page with that integration.
NOTION_TOKEN=

# The page the setup scripts create databases under (share it with the
# integration first). Copy the page ID from its URL.
NOTION_PARENT_PAGE_ID=

# Filled in by the setup scripts — run them once, then paste the printed
# IDs back here. See the README "Setup" section for the exact order.
NOTION_DATABASE_ID=
NOTION_DATA_SOURCE_ID=
NOTION_CATEGORIES_DB_ID=
NOTION_CATEGORIES_DATA_SOURCE_ID=
NOTION_MONTHLY_REPORTS_DB_ID=
NOTION_MONTHLY_REPORTS_DATA_SOURCE_ID=
